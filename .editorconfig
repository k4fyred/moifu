[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# =====================================
# Documentation Files
# =====================================

[*.md]
indent_style = space
indent_size = 2

# =====================================
# Configuration Files
# =====================================

[*.toml]
indent_style = space
indent_size = 2

# =====================================
# Project Source Code
# =====================================

[*.odin]
indent_style = tab
#indent_size = unset
